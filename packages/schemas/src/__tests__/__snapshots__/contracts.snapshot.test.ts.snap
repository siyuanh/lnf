exports[`contracts (privacy boundaries) > FindCreatedV1 1`] = `
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "findId": {
      "format": "uuid",
      "type": "string",
    },
    "locationKind": {
      "enum": [
