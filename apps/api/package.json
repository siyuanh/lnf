    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^12.0.1",
    "@types/node": "^20.16.0",
    "drizzle-kit": "^0.31.10",
    "testcontainers": "^12.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
